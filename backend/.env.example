# Server
PORT=3000
BASE_URL=https://waba-bitrix.premierchoiceint.online
# The deployed Nuxt frontend's URL (used for placement.bind on install)
FRONTEND_URL=https://waba-bitrix-app.premierchoiceint.online

# Bitrix24 Local Application (Developer Resources)
BITRIX_CLIENT_ID=
BITRIX_CLIENT_SECRET=

# OnCloud API (WhatsApp Cloud API BSP)
ONCLOUD_BASE_URL=https://apps.oncloudapi.com
# Preferred: static API token from the OnCloud dashboard (skips email/password login)
ONCLOUD_TOKEN=
# Fallback if no static token is issued
ONCLOUD_EMAIL=
ONCLOUD_PASSWORD=

# Per-executive daily send ceiling guardrail (FR guardrail 8.1)
DAILY_SEND_LIMIT_PER_EXECUTIVE=100

# FR-16: fallback wa.me destination when a /connect/:token is unknown/expired (optional)
FALLBACK_WHATSAPP_NUMBER=

# FR-17: brand cover image used when a project has no Drive file matching "cover" in its name
# Served by this backend itself from /public - see /static/whatsapp-cover.jpg
DEFAULT_COVER_IMAGE_URL=https://waba-bitrix.premierchoiceint.online/static/whatsapp-cover.jpg
